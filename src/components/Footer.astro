---
const legalLinks = [
  { href: '/privacy-policy', label: 'Privacy Policy' },
  { href: '/terms', label: 'Terms & Conditions' },
  { href: '/cookie-policy', label: 'Cookie Policy' },
];
---

<footer class="footer">
  <div class="container footer__inner">

    <div class="footer__brand">
      <div class="monogram" style="width:36px;height:36px;">
        <span style="font-size:0.85rem;">F/L</span>
      </div>
      <div>
        <p class="footer__name">The Face Lab Studio</p>
        <p class="footer__reg">The Face Lab By Paige Titchener Ltd &mdash; Company No. 16441048</p>
      </div>
    </div>

    <div class="footer__locations">
      <div class="footer__location">
        <p class="footer__location-name">Oxfordshire</p>
        <p>76 High Street, Witney, OX28 6HL</p>
      </div>
      <div class="footer__location">
        <p class="footer__location-name">Cotswolds</p>
        <p>The Riverside, Lechlade, GL7 3AQ</p>
      </div>
    </div>

    <div class="footer__right">
      <a href="/book" class="btn btn--outline footer__book-btn">Book Online</a>
      <!-- Fresha Highly Recommended 2026 Badge -->
      <div class="fresha-badge" title="Fresha Highly Recommended 2026">
        <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" aria-label="Fresha Highly Recommended 2026">
          <!-- Outer silver ring -->
          <circle cx="50" cy="50" r="48" fill="url(#silver)" stroke="#c8c4d4" stroke-width="1"/>
          <!-- Inner purple circle -->
          <circle cx="50" cy="50" r="40" fill="url(#purple)"/>
          <!-- Star notch at top -->
          <polygon points="50,8 53,15 60,12 57,19 64,19 58,24 61,31 54,27 50,34 46,27 39,31 42,24 36,19 43,19 40,12 47,15" fill="#c8c4d4"/>
          <!-- Inner ring detail -->
          <circle cx="50" cy="53" r="30" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="0.5"/>
          <!-- Text: Highly -->
          <text x="50" y="46" text-anchor="middle" font-family="Georgia, serif" font-size="9" font-weight="700" fill="white" letter-spacing="0.5">Highly</text>
          <!-- Text: Recommended -->
          <text x="50" y="57" text-anchor="middle" font-family="Georgia, serif" font-size="7.5" font-weight="700" fill="white" letter-spacing="0.3">Recommended</text>
          <!-- Text: 2026 -->
          <text x="50" y="67" text-anchor="middle" font-family="Georgia, serif" font-size="9" font-weight="700" fill="white" letter-spacing="0.5">2026</text>
          <!-- Text: fresha -->
          <text x="50" y="80" text-anchor="middle" font-family="Arial, sans-serif" font-size="6" font-weight="400" fill="rgba(255,255,255,0.75)" letter-spacing="1">fresha</text>
          <!-- Gradients -->
          <defs>
            <radialGradient id="silver" cx="40%" cy="35%" r="65%">
              <stop offset="0%" stop-color="#e8e4f0"/>
              <stop offset="50%" stop-color="#b8b4c8"/>
              <stop offset="100%" stop-color="#9890b0"/>
            </radialGradient>
            <radialGradient id="purple" cx="40%" cy="35%" r="65%">
              <stop offset="0%" stop-color="#7c6fbf"/>
              <stop offset="60%" stop-color="#5b4fa8"/>
              <stop offset="100%" stop-color="#4a3d96"/>
            </radialGradient>
          </defs>
        </svg>
      </div>
    </div>

  </div>

  <div class="container footer__bottom">
    <nav class="footer__legal" aria-label="Legal">
      {legalLinks.map(link => (
        <a href={link.href}>{link.label}</a>
      ))}
    </nav>
    <p class="footer__credit">
      Website by <a href="https://brandonburton.co.uk" style="text-decoration:underline;text-underline-offset:3px;">Brandon Burton</a>
    </p>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--rule);
    margin-top: var(--space-xl);
    padding-top: var(--space-lg);
    padding-bottom: var(--space-md);
  }

  .footer__inner {
    display: grid;
    grid-template-columns: 1fr auto auto;
    gap: var(--space-lg);
    align-items: start;
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--rule);
    margin-bottom: var(--space-md);
  }

  .footer__brand { display: flex; align-items: flex-start; gap: 0.75rem; }
  .footer__name { font-size: 0.85rem; font-weight: 500; margin-bottom: 0.2rem; }
  .footer__reg { font-size: 0.72rem; color: var(--soft); font-weight: 300; max-width: 260px; line-height: 1.5; }
  .footer__locations { display: flex; gap: var(--space-lg); }
  .footer__location { font-size: 0.8rem; color: var(--mid); font-weight: 300; }
  .footer__location-name { font-weight: 500; color: var(--ink); margin-bottom: 0.2rem; font-size: 0.8rem; }

  .footer__right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 1rem;
  }

  .footer__book-btn { font-size: 0.78rem; padding: 0.6rem 1.25rem; }

  /* Fresha badge SVG */
  .fresha-badge {
    width: 64px;
    height: 64px;
    opacity: 0.9;
    transition: opacity var(--transition);
    cursor: default;
  }

  .fresha-badge:hover { opacity: 1; }
  .fresha-badge svg { width: 100%; height: 100%; }

  /* Bottom bar */
  .footer__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .footer__legal { display: flex; gap: 1.25rem; flex-wrap: wrap; }
  .footer__legal a { font-size: 0.72rem; color: var(--soft); text-decoration: none; font-weight: 300; transition: color var(--transition); }
  .footer__legal a:hover { color: var(--ink); }
  .footer__credit { font-size: 0.72rem; color: var(--soft); font-weight: 300; }

  /* Mobile */
  @media (max-width: 900px) {
    .footer__inner { grid-template-columns: 1fr 1fr; }
    .footer__right { grid-column: 1 / -1; flex-direction: row; align-items: center; justify-content: space-between; }
  }

  @media (max-width: 600px) {
    .footer__inner { grid-template-columns: 1fr; gap: var(--space-md); }
    .footer__locations { flex-direction: column; gap: var(--space-sm); }
    .footer__right { flex-direction: row; align-items: center; justify-content: space-between; }
    .footer__bottom { flex-direction: column; align-items: flex-start; gap: 0.75rem; }
    .footer__legal { gap: 1rem; }
  }
</style>
