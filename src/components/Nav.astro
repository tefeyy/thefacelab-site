---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/gallery', label: 'Gallery' },
  { href: '/contact', label: 'Contact' },
];
const currentPath = Astro.url.pathname;
---

<header class="nav">
  <div class="container nav__inner">
    <a href="/" class="nav__logo">
      <div class="monogram" style="width:38px;height:38px;">
        <span style="font-size:0.9rem;">F/L</span>
      </div>
      <span class="nav__brand">The Face Lab Studio</span>
    </a>
    <nav class="nav__links" aria-label="Main navigation">
      {navLinks.map(link => (
        <a href={link.href} class={`nav__link ${currentPath === link.href ? 'nav__link--active' : ''}`}>
          {link.label}
        </a>
      ))}
      <div class="nav__dropdown">
        <button class="nav__link nav__dropdown-trigger">
          Treatments <span class="nav__chevron">&#9662;</span>
        </button>
        <div class="nav__dropdown-menu">
          <div class="nav__dropdown-menu-inner">
            <a href="/services-witney" class="nav__dropdown-item">
              <span class="nav__dropdown-label">Oxfordshire</span>
              <span class="nav__dropdown-sub">76 High Street, Witney</span>
            </a>
            <a href="/services-cotswolds" class="nav__dropdown-item">
              <span class="nav__dropdown-label">Cotswolds</span>
              <span class="nav__dropdown-sub">The Riverside, Lechlade</span>
            </a>
          </div>
        </div>
      </div>
    </nav>
    <a href="/book" class="btn btn--primary nav__cta">Book Now</a>
    <button class="nav__burger" aria-label="Toggle menu" id="nav-burger">
      <span></span><span></span><span></span>
    </button>
  </div>
  <div class="nav__mobile" id="nav-mobile">
    <nav class="nav__mobile-links">
      <a href="/" class="nav__mobile-link">Home</a>
      <div class="nav__mobile-section">
        <p class="nav__mobile-section-label">Treatments</p>
        <a href="/services-witney" class="nav__mobile-link nav__mobile-link--sub">Oxfordshire — Witney</a>
        <a href="/services-cotswolds" class="nav__mobile-link nav__mobile-link--sub">Cotswolds — Lechlade</a>
      </div>
      <a href="/about" class="nav__mobile-link">About</a>
      <a href="/gallery" class="nav__mobile-link">Gallery</a>
      <a href="/contact" class="nav__mobile-link">Contact</a>
      <div class="nav__mobile-book">
        <a href="https://www.fresha.com/a/the-face-lab-oxfordshire-witney-76-high-street-r5n80gwm" target="_blank" rel="noopener" class="btn btn--primary nav__mobile-book-btn">Book — Witney</a>
        <a href="https://www.fresha.com/a/the-face-lab-cotswolds-lechlade-the-riverside-park-end-wharf-ihomrrjm" target="_blank" rel="noopener" class="btn btn--primary nav__mobile-book-btn">Book — Cotswolds</a>
      </div>
    </nav>
  </div>
</header>

<script>
  const burger = document.getElementById('nav-burger');
  const mobileMenu = document.getElementById('nav-mobile');
  if (burger && mobileMenu) {
    burger.addEventListener('click', () => {
      const isOpen = mobileMenu.classList.toggle('nav__mobile--open');
      burger.classList.toggle('nav__burger--open', isOpen);
      document.body.style.overflow = isOpen ? 'hidden' : '';
    });
    mobileMenu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        mobileMenu.classList.remove('nav__mobile--open');
        burger.classList.remove('nav__burger--open');
        document.body.style.overflow = '';
      });
    });
  }
</script>
