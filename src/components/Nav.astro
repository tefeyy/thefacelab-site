---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/gallery', label: 'Gallery' },
  { href: '/contact', label: 'Contact' },
];
const currentPath = Astro.url.pathname;
---

<header class="nav">
  <div class="container nav__inner">
    <a href="/" class="nav__logo">
      <div class="monogram" style="width:38px;height:38px;">
        <span style="font-size:0.9rem;">F/L</span>
      </div>
      <span class="nav__brand">The Face Lab Studio</span>
    </a>

    <nav class="nav__links" aria-label="Main navigation">
      {navLinks.map(link => (
        <a href={link.href} class={`nav__link ${currentPath === link.href ? 'nav__link--active' : ''}`}>
          {link.label}
        </a>
      ))}
      <div class="nav__dropdown">
        <button class="nav__link nav__dropdown-trigger">
          Treatments <span class="nav__chevron">&#9662;</span>
        </button>
        <div class="nav__dropdown-menu">
          <div class="nav__dropdown-menu-inner">
            <a href="/services-witney" class="nav__dropdown-item">
              <span class="nav__dropdown-label">Oxfordshire</span>
              <span class="nav__dropdown-sub">76 High Street, Witney</span>
            </a>
            <a href="/services-cotswolds" class="nav__dropdown-item">
              <span class="nav__dropdown-label">Cotswolds</span>
              <span class="nav__dropdown-sub">The Riverside, Lechlade</span>
            </a>
          </div>
        </div>
      </div>
    </nav>

    <a href="/book" class="btn btn--primary nav__cta">Book Now</a>

    <button class="nav__burger" id="nav-burger" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </button>
  </div>

  <!-- Mobile menu: hidden via inline style, shown via JS inline style -->
  <div id="nav-mobile" style="display:none;position:fixed;top:68px;left:0;right:0;bottom:0;background:#faf9f7;overflow-y:auto;z-index:9999;border-top:1px solid #e4e2dd;">
    <nav style="display:flex;flex-direction:column;padding:1.5rem 1.25rem;">
      <a href="/" style="font-size:1.1rem;font-weight:300;color:#1a1a1a;padding:1rem 0;border-bottom:1px solid #e4e2dd;text-decoration:none;">Home</a>
      <div style="display:flex;flex-direction:column;border-bottom:1px solid #e4e2dd;padding:0.75rem 0;">
        <p style="font-size:0.72rem;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:#a0a0a0;margin-bottom:0.5rem;">Treatments</p>
        <a href="/services-witney" style="font-size:0.95rem;padding:0.6rem 0 0.6rem 0.75rem;color:#6b6b6b;text-decoration:none;">Oxfordshire — Witney</a>
        <a href="/services-cotswolds" style="font-size:0.95rem;padding:0.6rem 0 0.6rem 0.75rem;color:#6b6b6b;text-decoration:none;">Cotswolds — Lechlade</a>
      </div>
      <a href="/about" style="font-size:1.1rem;font-weight:300;color:#1a1a1a;padding:1rem 0;border-bottom:1px solid #e4e2dd;text-decoration:none;">About</a>
      <a href="/gallery" style="font-size:1.1rem;font-weight:300;color:#1a1a1a;padding:1rem 0;border-bottom:1px solid #e4e2dd;text-decoration:none;">Gallery</a>
      <a href="/contact" style="font-size:1.1rem;font-weight:300;color:#1a1a1a;padding:1rem 0;border-bottom:1px solid #e4e2dd;text-decoration:none;">Contact</a>
      <div style="display:flex;flex-direction:column;gap:0.75rem;margin-top:2rem;padding-bottom:2rem;">
        <a href="https://www.fresha.com/a/the-face-lab-oxfordshire-witney-76-high-street-r5n80gwm" target="_blank" rel="noopener" style="display:flex;align-items:center;justify-content:center;padding:0.875rem 1.75rem;background:#2a0d14;color:rgba(250,249,247,0.95);border-radius:8px;font-size:0.82rem;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;text-decoration:none;">Book — Witney</a>
        <a href="https://www.fresha.com/a/the-face-lab-cotswolds-lechlade-the-riverside-park-end-wharf-ihomrrjm" target="_blank" rel="noopener" style="display:flex;align-items:center;justify-content:center;padding:0.875rem 1.75rem;background:#2a0d14;color:rgba(250,249,247,0.95);border-radius:8px;font-size:0.82rem;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;text-decoration:none;">Book — Cotswolds</a>
      </div>
    </nav>
  </div>
</header>

<script>
(function() {
  var burger = document.getElementById('nav-burger');
  var menu = document.getElementById('nav-mobile');
  var isOpen = false;

  if (!burger || !menu) return;

  burger.addEventListener('click', function() {
    isOpen = !isOpen;
    menu.style.display = isOpen ? 'block' : 'none';
    document.body.style.overflow = isOpen ? 'hidden' : '';
    // Animate burger
    var spans = burger.querySelectorAll('span');
    if (isOpen) {
      spans[0].style.transform = 'translateY(6.5px) rotate(45deg)';
      spans[1].style.opacity = '0';
      spans[2].style.transform = 'translateY(-6.5px) rotate(-45deg)';
    } else {
      spans[0].style.transform = '';
      spans[1].style.opacity = '';
      spans[2].style.transform = '';
    }
  });

  // Close on any link click inside menu
  menu.querySelectorAll('a').forEach(function(link) {
    link.addEventListener('click', function() {
      isOpen = false;
      menu.style.display = 'none';
      document.body.style.overflow = '';
      var spans = burger.querySelectorAll('span');
      spans[0].style.transform = '';
      spans[1].style.opacity = '';
      spans[2].style.transform = '';
    });
  });
})();
</script>
