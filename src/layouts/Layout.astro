---
import '../styles/global.css';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
}

const { title, description, ogImage = '/og-default.jpg' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const path = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet" />
  <slot name="schema" />
</head>
<body>

<!-- ========== NAV ========== -->
<header id="site-nav">
  <div class="nav-inner">
    <a href="/" class="nav-logo">
      <div class="nav-monogram"><span>F/L</span></div>
      <span class="nav-brand">The Face Lab Studio</span>
    </a>
    <nav class="nav-desktop">
      <a href="/" class={`nav-link${path === '/' ? ' active' : ''}`}>Home</a>
      <div class="nav-drop">
        <button class="nav-link nav-drop-btn">Treatments &#9662;</button>
        <div class="nav-drop-panel">
          <a href="/services-witney" class="nav-drop-item">
            <strong>Oxfordshire</strong>
            <span>76 High Street, Witney</span>
          </a>
          <a href="/services-cotswolds" class="nav-drop-item">
            <strong>Cotswolds</strong>
            <span>The Riverside, Lechlade</span>
          </a>
        </div>
      </div>
      <a href="/about" class={`nav-link${path === '/about' ? ' active' : ''}`}>About</a>
      <a href="/gallery" class={`nav-link${path === '/gallery' ? ' active' : ''}`}>Gallery</a>
      <a href="/contact" class={`nav-link${path === '/contact' ? ' active' : ''}`}>Contact</a>
    </nav>
    <a href="/book" class="nav-book-btn">Book Now</a>
    <button id="burger" onclick="toggleMenu()" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<!-- ========== MOBILE MENU ========== -->
<div id="mobile-menu">
  <a href="/" onclick="toggleMenu()">Home</a>
  <div class="mob-section">
    <p>Treatments</p>
    <a href="/services-witney" onclick="toggleMenu()">&#8594; Oxfordshire — Witney</a>
    <a href="/services-cotswolds" onclick="toggleMenu()">&#8594; Cotswolds — Lechlade</a>
  </div>
  <a href="/about" onclick="toggleMenu()">About</a>
  <a href="/gallery" onclick="toggleMenu()">Gallery</a>
  <a href="/contact" onclick="toggleMenu()">Contact</a>
  <div class="mob-book">
    <a href="https://www.fresha.com/a/the-face-lab-oxfordshire-witney-76-high-street-r5n80gwm" target="_blank">Book — Witney</a>
    <a href="https://www.fresha.com/a/the-face-lab-cotswolds-lechlade-the-riverside-park-end-wharf-ihomrrjm" target="_blank">Book — Cotswolds</a>
  </div>
</div>

<script>
// Expose toggleMenu globally so onclick= attributes can find it
window.toggleMenu = function() {
  var m = document.getElementById('mobile-menu');
  var b = document.getElementById('burger');
  var open = m.style.display === 'block';
  m.style.display = open ? 'none' : 'block';
  b.classList.toggle('open', !open);
  document.body.style.overflow = open ? '' : 'hidden';
};
</script>

<style is:global>
#site-nav {
  position: sticky; top: 0; z-index: 1000;
  background: rgba(250,249,247,0.95);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid #e4e2dd;
}
.nav-inner {
  max-width: 1100px; margin: 0 auto;
  padding: 0 1.5rem;
  display: flex; align-items: center; gap: 1.5rem; height: 68px;
}
.nav-logo { display: flex; align-items: center; gap: 0.75rem; text-decoration: none; flex-shrink: 0; }
.nav-monogram {
  width: 38px; height: 38px; background: #2a0d14; border-radius: 8px;
  display: flex; align-items: center; justify-content: center;
}
.nav-monogram span { font-style: italic; font-weight: 300; color: rgba(250,249,247,0.9); font-size: 0.9rem; }
.nav-brand { font-size: 0.78rem; font-weight: 500; letter-spacing: 0.04em; text-transform: uppercase; color: #6b6b6b; }
.nav-desktop { display: flex; align-items: center; gap: 0.25rem; margin-left: auto; }
.nav-link {
  font-size: 0.82rem; color: #6b6b6b; padding: 0.4rem 0.75rem;
  border-radius: 6px; text-decoration: none; background: none; border: none;
  cursor: pointer; font-family: inherit; transition: all 0.2s;
}
.nav-link:hover, .nav-link.active { color: #1a1a1a; background: rgba(42,13,20,0.08); }
.nav-drop { position: relative; }
.nav-drop-btn { display: flex; align-items: center; gap: 0.3rem; }
.nav-drop-panel {
  display: none; position: absolute; top: calc(100% + 0.5rem); left: 50%;
  transform: translateX(-50%); min-width: 220px;
  background: #faf9f7; border: 1px solid #e4e2dd; border-radius: 12px;
  box-shadow: 0 8px 32px rgba(0,0,0,0.1); overflow: hidden; z-index: 200;
}
.nav-drop:hover .nav-drop-panel { display: block; }
.nav-drop-item {
  display: flex; flex-direction: column; padding: 0.875rem 1.25rem;
  text-decoration: none; border-bottom: 1px solid #e4e2dd; transition: background 0.2s;
}
.nav-drop-item:last-child { border-bottom: none; }
.nav-drop-item:hover { background: rgba(42,13,20,0.06); }
.nav-drop-item strong { font-size: 0.85rem; color: #1a1a1a; font-weight: 500; }
.nav-drop-item span { font-size: 0.75rem; color: #a0a0a0; margin-top: 0.1rem; }
.nav-book-btn {
  font-size: 0.78rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase;
  padding: 0.6rem 1.25rem; background: #2a0d14; color: rgba(250,249,247,0.95);
  border-radius: 8px; text-decoration: none; margin-left: 0.5rem; flex-shrink: 0;
  transition: background 0.2s;
}
.nav-book-btn:hover { background: #3d1220; }

/* Burger */
#burger {
  display: none; flex-direction: column; gap: 5px;
  background: none; border: none; cursor: pointer; padding: 0.5rem; margin-left: auto;
}
#burger span {
  display: block; width: 22px; height: 1.5px; background: #1a1a1a;
  transition: all 0.25s; transform-origin: center;
}
#burger.open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
#burger.open span:nth-child(2) { opacity: 0; }
#burger.open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

/* Mobile menu */
#mobile-menu {
  display: none;
  position: fixed; top: 68px; left: 0; right: 0; bottom: 0;
  background: #faf9f7; overflow-y: auto; z-index: 999;
  border-top: 1px solid #e4e2dd;
  flex-direction: column; padding: 1.5rem 1.25rem;
}
#mobile-menu a {
  font-size: 1.1rem; font-weight: 300; color: #1a1a1a;
  padding: 1rem 0; border-bottom: 1px solid #e4e2dd;
  text-decoration: none; display: block;
}
.mob-section { border-bottom: 1px solid #e4e2dd; padding: 0.75rem 0; }
.mob-section p { font-size: 0.72rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: #a0a0a0; margin-bottom: 0.5rem; }
.mob-section a { font-size: 0.95rem; color: #6b6b6b; padding: 0.5rem 0 0.5rem 0.75rem; border-bottom: none; }
.mob-book { display: flex; flex-direction: column; gap: 0.75rem; margin-top: 2rem; padding-bottom: 2rem; }
.mob-book a {
  display: flex; align-items: center; justify-content: center;
  padding: 0.875rem; background: #2a0d14; color: rgba(250,249,247,0.95);
  border-radius: 8px; font-size: 0.82rem; font-weight: 600;
  letter-spacing: 0.08em; text-transform: uppercase; border-bottom: none;
}

@media (max-width: 768px) {
  .nav-desktop { display: none; }
  .nav-book-btn { display: none; }
  #burger { display: flex; }
}
@media (min-width: 769px) {
  #mobile-menu { display: none !important; }
}
</style>
<!-- ========== END NAV ========== -->

<main>
  <slot />
</main>
<Footer />

</body>
</html>
